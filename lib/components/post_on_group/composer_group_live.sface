<Bonfire.UI.Common.SmartInputButtonLive
  :if={current_user(@__context__)}
  smart_input_opts={%{
    context_id: id(@category),
    text_suggestion: "+#{e(@category, :character, :username, nil)}",
    to_circles: Bonfire.Classify.Boundaries.post_circles_for_group(@category),
    to_boundaries: [Bonfire.Classify.Boundaries.read_default_content_visibility(@category)]
  }}
  prompt={l("Write in group")}
  class="btn btn-sm btn-primary"
/>
